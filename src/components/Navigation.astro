---
const navItems = [
  { href: '/', label: 'Inicio' },
  { href: '/explora', label: 'Explora' },
  { href: '/historia', label: 'Historia' },
  { href: '/que-ver', label: 'Qué ver' },
  { href: '/eventos', label: 'Eventos' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  style="background: transparent;"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo: torre medieval + nombre -->
      <a
        href="/"
        class="flex items-center gap-2.5 group"
        aria-label="Arcusa - Inicio"
        style="text-decoration: none;"
      >
        <!-- SVG del torreón medieval de Arcusa -->
        <svg
          viewBox="0 0 22 30"
          width="28"
          height="36"
          fill="currentColor"
          class="text-white drop-shadow-md transition-transform duration-300 group-hover:scale-110"
          aria-hidden="true"
        >
          <!-- Almenas (battlements) -->
          <rect x="1"  y="0" width="4.5" height="7" rx="0.5"/>
          <rect x="7"  y="0" width="4.5" height="7" rx="0.5"/>
          <rect x="13" y="0" width="4.5" height="7" rx="0.5"/>
          <rect x="19" y="0" width="2"   height="7" rx="0.5"/>
          <!-- Cuerpo torre alto -->
          <rect x="1" y="6" width="20" height="14" rx="0.5"/>
          <!-- Ventana ajimez (saeteras) -->
          <rect x="9" y="9" width="4" height="7" rx="2" fill="rgba(0,0,0,0.35)"/>
          <!-- Base más ancha -->
          <rect x="0" y="20" width="22" height="10" rx="0.5"/>
          <!-- Puerta -->
          <rect x="8.5" y="24" width="5" height="6" rx="2.5" fill="rgba(0,0,0,0.35)"/>
        </svg>
        <span
          class="font-serif font-semibold text-xl text-white drop-shadow-md leading-none"
          style="letter-spacing: -0.01em;"
        >
          Arcusa
        </span>
      </a>

      <!-- Nav desktop -->
      <nav aria-label="Navegación principal" class="hidden md:flex items-center gap-1">
        {navItems.map(item => {
          const isActive = currentPath === item.href ||
            (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class="relative px-3 py-2 text-sm font-medium transition-colors duration-200 rounded-lg"
              style={isActive
                ? 'color: white;'
                : 'color: rgba(255,255,255,0.78);'}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
              {isActive && (
                <span
                  class="absolute bottom-0 left-3 right-3 h-0.5 rounded-full"
                  style="background: white;"
                />
              )}
              <span
                class="absolute inset-0 rounded-lg opacity-0 hover:opacity-100 transition-opacity duration-200"
                style="background: rgba(255,255,255,0.08);"
              />
            </a>
          );
        })}
      </nav>

      <!-- Botón menú móvil -->
      <button
        id="menu-toggle"
        class="md:hidden text-white p-2 rounded-lg transition-colors hover:bg-white/10"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8"
             stroke-linecap="round" viewBox="0 0 24 24">
          <path d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" stroke-width="1.8"
             stroke-linecap="round" viewBox="0 0 24 24">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <div
    id="mobile-menu"
    class="md:hidden hidden"
    style="background: rgba(36,32,28,0.97); backdrop-filter: blur(16px); border-top: 1px solid rgba(255,255,255,0.06);"
  >
    <nav aria-label="Menú móvil" class="px-4 py-3 flex flex-col gap-1">
      {navItems.map(item => {
        const isActive = currentPath === item.href ||
          (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class="block px-4 py-3 rounded-xl text-sm font-medium transition-colors"
            style={isActive
              ? 'background: rgba(255,255,255,0.1); color: white;'
              : 'color: rgba(255,255,255,0.65);'}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  const nav = document.getElementById('nav')!;
  const toggle = document.getElementById('menu-toggle')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  const updateNav = () => {
    if (window.scrollY > 60) {
      nav.style.background = 'rgba(36,32,28,0.95)';
      nav.style.backdropFilter = 'blur(16px)';
      nav.style.boxShadow = '0 1px 0 rgba(255,255,255,0.04), 0 4px 16px rgba(0,0,0,0.2)';
    } else {
      nav.style.background = 'transparent';
      nav.style.backdropFilter = 'none';
      nav.style.boxShadow = 'none';
    }
  };

  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  toggle.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
