---
import Icon from './Icon.astro';

interface Props {
  titulo: string;
  fecha: string;
  hora?: string;
  lugar: string;
  descripcion: string;
  imagen?: string;
  categoria: string;
  slug: string;
  pasado?: boolean;
}

const { titulo, fecha, hora, lugar, descripcion, imagen, categoria, slug, pasado = false } = Astro.props;

const categoriaConfig: Record<string, { label: string; icon: string; color: string }> = {
  fiesta:    { label: 'Fiesta',    icon: 'sparkles',  color: '#C4773D' },
  cultura:   { label: 'Cultura',   icon: 'palette',   color: '#5B7FA6' },
  mercado:   { label: 'Mercado',   icon: 'home',      color: '#4F6E45' },
  actividad: { label: 'Actividad', icon: 'footprints',color: '#3E5C3A' },
  museo:     { label: 'Museo',     icon: 'frame',     color: '#9C8567' },
};

const cfg = categoriaConfig[categoria] ?? { label: categoria, icon: 'calendar', color: '#9C8567' };

const fechaObj = new Date(fecha + 'T00:00:00');
const dia = fechaObj.toLocaleDateString('es-ES', { day: 'numeric' });
const mes = fechaObj.toLocaleDateString('es-ES', { month: 'short' }).toUpperCase().replace('.', '');
---

<article
  class:list={[
    'reveal rounded-2xl overflow-hidden flex flex-col sm:flex-row transition-all duration-300',
    pasado ? 'opacity-55' : 'hover:-translate-y-1',
  ]}
  style="background: white; border: 1px solid rgba(156,133,103,0.12); box-shadow: 0 2px 8px rgba(46,42,36,0.05);"
>
  <!-- Columna fecha -->
  <div
    class="flex-shrink-0 flex sm:flex-col items-center sm:justify-center px-5 py-4 sm:py-5 sm:w-20 gap-3 sm:gap-0.5"
    style={`background: ${pasado ? 'var(--color-piedra-clara)' : 'var(--color-verde-pino)'}; color: white;`}
  >
    <span class="text-3xl font-bold font-serif leading-none">{dia}</span>
    <span class="text-xs font-semibold tracking-wider mt-0.5 opacity-80">{mes}</span>
    {hora && <span class="text-xs mt-2 opacity-65 sm:mt-2 ml-auto sm:ml-0">{hora}</span>}
  </div>

  <!-- Contenido -->
  <div class="p-4 sm:p-5 flex flex-col gap-2 flex-1 min-w-0">
    <div class="flex items-start gap-2">
      <h3 class="font-serif text-base font-semibold leading-snug flex-1" style="color: var(--color-carbon);">
        {titulo}
      </h3>
      <!-- Categoría badge -->
      <span
        class="flex items-center gap-1 text-xs font-medium px-2 py-0.5 rounded-full flex-shrink-0 mt-0.5"
        style={`background: ${cfg.color}18; color: ${cfg.color};`}
      >
        <Icon name={cfg.icon} size={10} />
        {cfg.label}
      </span>
    </div>

    <p class="flex items-center gap-1.5 text-xs" style="color: var(--color-piedra-media);">
      <Icon name="map-pin" size={11} />
      {lugar}
    </p>

    <p class="text-sm leading-relaxed line-clamp-2" style="color: var(--color-carbon-suave);">
      {descripcion}
    </p>

    <a
      href={`/eventos/${slug}`}
      class="mt-auto self-start flex items-center gap-1 text-xs font-semibold transition-colors hover:opacity-75"
      style="color: var(--color-azul-pirineo); padding-top: 4px;"
    >
      Ver detalles
      <Icon name="arrow-right" size={12} />
    </a>
  </div>
</article>
