  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cls}
  style={style}
  aria-hidden={ariaHidden}
  aria-label={ariaLabel}
>
