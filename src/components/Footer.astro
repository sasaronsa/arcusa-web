---
import { pueblo } from '../data/pueblo';

interface Props {
  // Se mantiene por compatibilidad con las páginas que lo pasan; el pie es
  // minimalista e idéntico en todas.
  completo?: boolean;
}
const year = new Date().getFullYear();

const navItems = [
  { href: '/explora',        label: 'Explora' },
  { href: '/historia',       label: 'Patrimonio' },
  { href: '/que-ver',        label: 'Experiencias' },
  { href: '/museo',          label: 'Museo' },
  { href: '/arcusa-de-noche', label: 'Noches' },
  { href: '/eventos',        label: 'Agenda' },
];
---

<footer style="background: var(--color-carbon);" class="mt-auto">
  <!-- Línea de acento fina -->
  <div
    class="h-px w-full"
    style="background: linear-gradient(90deg, transparent, var(--color-ocre) 50%, transparent); opacity: 0.55;"
  />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-7">
    <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
      <!-- Marca -->
      <a href="/" class="flex items-center gap-2.5" style="text-decoration: none;">
        <svg viewBox="0 0 22 30" width="16" height="21" fill="white" aria-hidden="true">
          <rect x="1"  y="0" width="4.5" height="7" rx="0.5"/>
          <rect x="7"  y="0" width="4.5" height="7" rx="0.5"/>
          <rect x="13" y="0" width="4.5" height="7" rx="0.5"/>
          <rect x="19" y="0" width="2"   height="7" rx="0.5"/>
          <rect x="1"  y="6" width="20" height="14" rx="0.5"/>
          <rect x="9"  y="9" width="4" height="7" rx="2" fill="rgba(0,0,0,0.4)"/>
          <rect x="0"  y="20" width="22" height="10" rx="0.5"/>
          <rect x="8.5" y="24" width="5" height="6" rx="2.5" fill="rgba(0,0,0,0.4)"/>
        </svg>
        <span class="font-serif text-lg font-semibold text-white leading-none">Arcusa</span>
        <span class="hidden sm:inline text-xs" style="color: var(--color-piedra-media);">
          · Pueblo Museo del Sobrarbe
        </span>
      </a>

      <!-- Navegación en línea -->
      <nav aria-label="Pie de página" class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
        {navItems.map(item => (
          <a
            href={item.href}
            class="transition-colors hover:text-white"
            style="color: var(--color-piedra-clara);"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <!-- Línea legal -->
    <div
      class="mt-6 pt-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs"
      style="border-top: 1px solid rgba(205,187,160,0.1); color: var(--color-piedra-media);"
    >
      <p>© {year} Arcusa · hecho por un vecino del pueblo</p>
      <a
        href={`mailto:${pueblo.email}`}
        class="underline underline-offset-2 hover:text-white transition-colors break-all"
      >
        {pueblo.email}
      </a>
    </div>
  </div>
</footer>
