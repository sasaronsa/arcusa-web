---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
  dark?: boolean;
}

const { eyebrow, title, subtitle, centered = false, dark = false } = Astro.props;
---

<div class:list={['mb-12 reveal', centered && 'text-center']}>
  {eyebrow && (
    <div class:list={['flex items-center gap-3 mb-4', centered && 'justify-center']}>
      <span
        class="block w-6 h-px flex-shrink-0"
        style={dark ? 'background: rgba(255,255,255,0.3);' : 'background: var(--color-ocre);'}
      />
      <p
        class="text-xs font-semibold uppercase tracking-[0.2em]"
        style={dark ? 'color: rgba(255,255,255,0.55);' : 'color: var(--color-ocre);'}
      >
        {eyebrow}
      </p>
    </div>
  )}
  <h2
    class="font-serif leading-tight"
    style={`
      font-size: clamp(1.75rem, 4vw, 2.75rem);
      font-weight: 700;
      color: ${dark ? 'white' : 'var(--color-carbon)'};
    `}
  >
    {title}
  </h2>
  {subtitle && (
    <p
      class:list={[
        'mt-4 text-lg max-w-2xl leading-relaxed',
        centered && 'mx-auto',
      ]}
      style={dark ? 'color: rgba(255,255,255,0.72);' : 'color: var(--color-carbon-suave);'}
    >
      {subtitle}
    </p>
  )}
</div>
