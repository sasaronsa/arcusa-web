</style>

<script>
  function setupLugaresModales() {
    const abrir = (id: string) => {
      const m = document.getElementById(id);
      if (!m) return;
      m.classList.add('open');
      m.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const cerrar = (m: Element) => {
      m.classList.remove('open');
      m.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    document.querySelectorAll<HTMLElement>('[data-open-modal]').forEach(btn => {
      btn.addEventListener('click', () => abrir(btn.dataset.openModal!));
    });
    document.querySelectorAll<HTMLElement>('[data-close-modal]').forEach(el => {
      el.addEventListener('click', () => {
        const m = el.closest('.lugares-modal');
        if (m) cerrar(m);
      });
    });
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') {
        document.querySelectorAll('.lugares-modal.open').forEach(cerrar);
      }
    });
  }
  setupLugaresModales();
</script>
