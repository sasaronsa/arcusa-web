---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MapaArcusa from '../components/MapaArcusa.astro';
import CardLugar from '../components/CardLugar.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

// Servicios del pueblo (puntos tipo "servicio"), agrupados por categoría
// para los modales de Dormir y Comer.
const servicios = (await getCollection('puntos')).filter(p => p.data.tipo === 'servicio');
const alojamientosZona = servicios.filter(p => p.data.categoria === 'dormir');
const restaurantesZona = servicios.filter(p => p.data.categoria === 'comer');

// Mapa del pueblo (se mantiene el mapa interactivo actual)
const puntos = (await getCollection('puntos')).filter(p => p.data.enMapa !== false).map(p => ({
  slug: p.id.split('/').pop()!,
  nombre: p.data.nombre,
  tipo: p.data.tipo,
  x: p.data.x,
  y: p.data.y,
  resumen: p.data.resumen,
  imagenes: p.data.imagenes,
  anio: p.data.anio,
  autor: p.data.autor,
}));

// ── Navegación interna de la página ───────────────
const indice = [
  { label: 'Imprescindibles', href: '#imprescindibles' },
  { label: 'Qué visitar',     href: '#visitar' },
  { label: 'Actividades',     href: '#actividades' },
  { label: 'Experiencias',    href: '#experiencias' },
  { label: 'Gastronomía',     href: '#gastronomia' },
  { label: 'Dormir',          href: '#dormir' },
  { label: 'Itinerarios',     href: '#itinerarios' },
  { label: 'Mapa',            href: '#mapa' },
];

// ── Por qué alojarte en Arcusa ────────────────────
const porQue = [
  { icon: 'compass',   titulo: 'Todo a un paso',     texto: 'Aínsa, Ordesa, Guara, Alquézar. Sales por la mañana y a mediodía estás de vuelta a comer. Aquí no se pierde medio viaje conduciendo.' },
  { icon: 'tree-pine', titulo: 'Silencio de verdad', texto: 'Cuando cae el día, el mayor ruido de Arcusa es el viento entre las montañas. Ni colas, ni bocinas, ni prisa.' },
  { icon: 'star',      titulo: 'La noche se ve',     texto: 'El Sobrarbe es Destino Starlight. Levantas la vista y ahí está la Vía Láctea, como antes de que existieran las ciudades.' },
  { icon: 'palette',   titulo: 'Patrimonio vivo',    texto: 'Calles de piedra y un museo pintado en las fachadas. En Arcusa no duermes al lado de la historia: duermes dentro.' },
];

// ── Imprescindibles (4 grandes) ───────────────────
const imprescindibles = [
  {
    nombre: 'Aínsa',
    eyebrow: 'Villa medieval',
    distancia: '~15 min',
    icon: 'castle',
    img: '/images/que-ver/ainsa.webp',
    grad: 'linear-gradient(135deg, #C3D7E6 0%, #7F9BBE 100%)',
    desc: 'Cruzas la puerta de la muralla y, de golpe, estás en el siglo XII. La plaza porticada, el castillo, las callejuelas. Sube al atardecer: cuando el sol cae tras los Pirineos, nadie habla.',
  },
  {
    nombre: 'Alquézar',
    eyebrow: 'Pueblo y cañón',
    distancia: '~45 min',
    icon: 'church',
    img: '/images/que-ver/alquezar.webp',
    grad: 'linear-gradient(135deg, #E8A96A 0%, #C4773D 100%)',
    desc: 'Un puñado de casas colgadas sobre el cañón del Vero, con la colegiata vigilando desde arriba. Y abajo, las pasarelas suspendidas sobre el río: el paseo que todo el mundo acaba haciendo. Da un poco de vértigo. Merece cada paso.',
  },
  {
    nombre: 'Parque Nacional de Ordesa',
    eyebrow: 'Naturaleza mayúscula',
    distancia: '~1 h',
    icon: 'mountain',
    img: '/images/que-ver/ordesa.webp',
    grad: 'linear-gradient(135deg, #7C8A5C 0%, #3E5C3A 100%)',
    desc: 'Hay sitios que impresionan en una foto. Ordesa impresiona mucho más cuando estás dentro. Valles tallados por el hielo, cascadas una detrás de otra y paredes que te obligan a mirar hacia arriba. Se va una vez y se vuelve toda la vida.',
  },
  {
    nombre: 'Sierra de Guara',
    eyebrow: 'Roca y agua',
    distancia: '~40 min',
    icon: 'waves',
    img: '/images/que-ver/guara.webp',
    grad: 'linear-gradient(135deg, #CDBBA0 0%, #6B5842 100%)',
    desc: 'El reino de los cañones. Agua turquesa abriéndose paso entre paredes de roca que lleva milenios esculpiendo. Es la capital mundial del barranquismo, pero no hace falta tirarse: basta con asomarse.',
  },
];

// ── Qué visitar (por categorías) ──────────────────
const visitar = [
  {
    titulo: 'Pueblos',
    eyebrow: 'Para perderse a pie',
    icon: 'home',
    items: [
      { n: 'Aínsa',       d: 'La plaza medieval más bonita de Aragón. Sin discusión.' },
      { n: 'Alquézar',    d: 'Calles que cuelgan sobre el cañón del Vero.' },
      { n: 'Boltaña',     d: 'Casco antiguo y castillo junto al río Ara.' },
      { n: 'Abizanda',    d: 'Su torre del siglo XI vigila el embalse de Mediano.' },
      { n: 'Lecina',      d: 'Piedra y leña, a la sombra de una carrasca milenaria.' },
      { n: 'Samitier',    d: 'Cuatro casas, una ermita en la roca y vistas que no acaban.' },
      { n: 'Escanilla',   d: 'El Sobrarbe tranquilo, entre campos y montaña.' },
      { n: 'Morcat',      d: 'Casi deshabitado. Aquí empezó la historia de Arcusa.' },
      { n: 'Muro de Roda', d: 'Un pueblo fortificado entero, hoy en silencio.' },
    ],
  },
  {
    titulo: 'Patrimonio',
    eyebrow: 'Mil años de piedra',
    icon: 'landmark',
    items: [
      { n: 'Torre de Arcusa',          d: 'La atalaya pentagonal del pueblo, en pie desde el siglo XI.' },
      { n: 'Dolmen de Pueyoril',       d: 'Cinco mil años de memoria, a un paseo de Arcusa.' },
      { n: 'Castillo de Samitier',     d: 'Castillo y ermita románica asomados al embalse.' },
      { n: 'Castillo de Abizanda',     d: 'Torre del siglo XI con el horizonte entero a sus pies.' },
      { n: 'Monasterio de San Victorián', d: 'De los más antiguos de España, al pie de la Peña Montañesa.' },
      { n: 'Muro de Roda',             d: 'Murallas, iglesia y torreones que resistieron mil años.' },
    ],
  },
  {
    titulo: 'Naturaleza',
    eyebrow: 'Paisaje en estado puro',
    icon: 'mountain',
    items: [
      { n: 'P. N. de Ordesa y Monte Perdido', d: 'El gran parque nacional del Pirineo. Palabras mayores.' },
      { n: 'Sierra de Guara',          d: 'Donde el agua decidió cortar la roca.' },
      { n: 'Cañón del Vero',           d: 'Arte rupestre Patrimonio Mundial y pasarelas sobre el agua.' },
      { n: 'Congosto de Entremón',     d: 'Un tajo vertical sobre el embalse que casi nadie conoce.' },
      { n: 'Peña Montañesa',           d: 'La mole que se ve desde cualquier rincón del Sobrarbe.' },
      { n: 'Miradores',                d: 'Balcones naturales con los Pirineos de fondo.' },
    ],
  },
];

// ── Actividades ───────────────────────────────────
const actividades = [
  {
    titulo: 'Senderismo',
    icon: 'footprints',
    items: [
      { n: 'GR-1, Sendero Histórico', d: 'La gran ruta que cruza el Prepirineo de lado a lado.' },
      { n: 'Ruta del Dolmen',         d: 'Un paseo corto desde Arcusa hasta la Prehistoria.' },
      { n: 'Subida a Samitier',       d: 'Castillo, ermita y un balcón sobre el embalse.' },
      { n: 'Peña Montañesa',          d: 'Dura de subir. Imposible de olvidar desde arriba.' },
    ],
  },
  {
    titulo: 'Aventura',
    icon: 'waves',
    items: [
      { n: 'Barranquismo', d: 'En Guara, donde se inventó casi todo esto.' },
      { n: 'Kayak',        d: 'Remar en silencio por los embalses del Sobrarbe.' },
      { n: 'Rafting',      d: 'Aguas bravas en el Ara y el Cinca.' },
      { n: 'Escalada',     d: 'Paredes para empezar y paredes para respetar.' },
      { n: 'Vías ferratas', d: 'Verticalidad y vértigo, con la seguridad puesta.' },
      { n: 'BTT',          d: 'Kilómetros de pistas entre pueblos y bosques.' },
    ],
  },
  {
    titulo: 'Naturaleza',
    icon: 'tree-pine',
    items: [
      { n: 'Observación de aves', d: 'Uno de los mejores cielos de España para mirar arriba.' },
      { n: 'Quebrantahuesos',     d: 'El rey del Pirineo, planeando sobre tu cabeza.' },
      { n: 'Astrofotografía',     d: 'Cielos Starlight para llevarte la Vía Láctea a casa.' },
      { n: 'La berrea',           d: 'El bramido de los ciervos rompiendo el otoño.' },
      { n: 'Micología',           d: 'Cuando llega el frío, el bosque se llena de setas.' },
    ],
  },
];

// ── Experiencias ──────────────────────────────────
const experiencias = [
  { icon: 'sunrise',  texto: 'Ver amanecer desde un mirador, con el valle todavía dormido bajo la niebla.' },
  { icon: 'waves',    texto: 'Meterte en una poza de agua turquesa cuando aprieta el calor de agosto.' },
  { icon: 'castle',   texto: 'Perderte por un pueblo medieval sin mapa, sin prisa y sin rumbo.' },
  { icon: 'palette',  texto: 'Ir cazando los murales de Arcusa, de fachada en fachada.' },
  { icon: 'star',     texto: 'Quedarte callado mirando un cielo con más estrellas de las que recordabas.' },
  { icon: 'mountain', texto: 'Ver planear un quebrantahuesos sobre los cañones de Guara.' },
  { icon: 'tree-pine', texto: 'Escuchar la berrea de los ciervos en un atardecer de octubre.' },
  { icon: 'footprints', texto: 'Cruzar las pasarelas del Vero, suspendido sobre el río.' },
];

// ── Gastronomía ───────────────────────────────────
const gastronomiaImg = '/images/que-ver/gastronomia.webp'
const productos = [
  { n: 'Ternasco de Aragón', icon: 'utensils' },
  { n: 'Chiretas',           icon: 'utensils' },
  { n: 'Longaniza',          icon: 'utensils' },
  { n: 'Quesos del Pirineo', icon: 'utensils' },
  { n: 'Miel de montaña',    icon: 'sparkles' },
  { n: 'Aceite',             icon: 'sparkles' },
  { n: 'Vinos D.O. Somontano', icon: 'star' },
];

// ── Dormir ────────────────────────────────────────
const alojamiento = [
  { icon: 'home',     titulo: 'Casas rurales',  texto: 'La forma más honesta de dormir en el Sobrarbe. En la propia Arcusa, piedra con siglos y chimenea encendida.' },
  { icon: 'building', titulo: 'Hoteles',        texto: 'En Aínsa, Boltaña y alrededores, desde hoteles con encanto a opciones para toda la familia.' },
  { icon: 'tree-pine', titulo: 'Campings',      texto: 'Para los que prefieren dormirse oyendo el río y despertarse entre pinos.' },
  { icon: 'bed',      titulo: 'Apartamentos',   texto: 'Tu espacio y tu ritmo, ideales para estancias largas o viajes en familia.' },
];

// ── Itinerarios ───────────────────────────────────
const itinerarios = [
  { tiempo: 'Medio día',   icon: 'clock',    titulo: 'Aínsa al atardecer',     plan: 'Piérdete por el casco medieval, sube al castillo y quédate a ver caer el sol sobre los Pirineos. Cena con calma de vuelta en Arcusa.' },
  { tiempo: 'Un día',      icon: 'sunrise',  titulo: 'Alquézar y el Vero',     plan: 'Madruga hacia Alquézar, cruza las pasarelas del cañón y come en el pueblo. Por la tarde, un baño en una poza si el calor lo pide.' },
  { tiempo: 'Fin de semana', icon: 'calendar', titulo: 'Ordesa + Sobrarbe',   plan: 'Un día entero en Ordesa para la naturaleza grande. Otro, sin reloj, entre Aínsa, los pueblos cercanos y la historia de Arcusa.' },
  { tiempo: '3 días',      icon: 'star',     titulo: 'La inmersión total',     plan: 'Súmale una jornada de aventura en Guara —barranco o ferrata— y tiempo para los rincones que no salen en las guías.' },
];

// ── Según la época ────────────────────────────────
const estaciones = [
  { estacion: 'Primavera', icon: 'tree-pine', texto: 'Con el deshielo, cascadas y barrancos van a tope. Todo verde y los pueblos aún para ti solo.' },
  { estacion: 'Verano',    icon: 'waves',     texto: 'Tiempo de pozas, barrancos y noches templadas para tumbarse a mirar las estrellas.' },
  { estacion: 'Otoño',     icon: 'star',      texto: 'El bosque se vuelve de oro, brama la berrea y salen las setas. Para muchos, la mejor época.' },
  { estacion: 'Invierno',  icon: 'sparkles',  texto: 'Nieve en las cumbres, silencio abajo y un Sobrarbe en calma para desconectar de todo.' },
];

// ── Familia ───────────────────────────────────────
const familia = [
  'Las pasarelas del Vero: aventura de verdad, pero segura. A los niños les encanta.',
  'Pozas y orillas tranquilas para chapotear todo el verano.',
  'El museo al aire libre de Arcusa, que se convierte en un juego de buscar murales.',
  'Buitres, quebrantahuesos y ciervos: fauna que se ve sin ser un experto.',
  'Pueblos medievales para explorar como si fueran castillos de cuento.',
];

// ── Rincones poco conocidos ───────────────────────
const rincones = [
  { n: 'Muro de Roda',          d: 'Una fortaleza olvidada entre montañas. Aquí solo se oye el viento, y la subida se paga con las vistas.' },
  { n: 'La Carrasca de Lecina', d: 'Mil años llevando contemplando el Sobrarbe. Una encina tan grande que te hace sentir pequeño.' },
  { n: 'Congosto de Entremón',  d: 'Un desfiladero donde el agua partió la montaña en dos. Y casi nadie lo conoce.' },
  { n: 'Castillo de Samitier',  d: 'Un castillo y una ermita colgados sobre el vacío. Súbete y entenderás por qué los pusieron ahí.' },
  { n: 'Peña Montañesa',        d: 'Hay montañas que se escalan. La Peña Montañesa se admira.' },
  { n: 'Aldeas despobladas',    d: 'Morcat, Bagüeste y otros núcleos donde el tiempo se paró hace años.' },
];
---

<Layout
  title="Descubre el Sobrarbe desde Arcusa – Qué ver y hacer"
  description="Arcusa es el mejor punto de partida para descubrir el Sobrarbe: Aínsa, Alquézar, Ordesa, la Sierra de Guara, pueblos medievales, cañones, rutas y experiencias en el Pirineo aragonés."
>
  <Navigation />

  <!-- ══════════ 1 · HERO ══════════ -->
  <section
    class="relative flex items-end overflow-hidden"
    style="height: 88svh; min-height: 600px;"
    aria-label="Descubre el Sobrarbe desde Arcusa"
  >
    <img
      src="/images/hero/Header4.webp"
      alt="Paisaje de montañas del Sobrarbe, en el Pirineo aragonés"
      class="absolute inset-0 w-full h-full object-cover"
      style="object-position: center 30%;"
      fetchpriority="high"
    />
    <!-- Velo para legibilidad -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to top, rgba(20,24,28,0.78) 0%, rgba(20,24,28,0.32) 45%, rgba(20,24,28,0.18) 100%);"
    ></div>
    <!-- Transición al cuerpo -->
    <div
      class="absolute inset-x-0 bottom-0 h-32 pointer-events-none"
      style="background: linear-gradient(to bottom, transparent, var(--color-pergamino));"
    ></div>

    <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 md:pb-28">
      <div
        class="inline-flex items-center gap-2 mb-6 px-4 py-1.5 rounded-full"
        style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.18); color: rgba(255,255,255,0.85);"
      >
        <Icon name="map-pin" size={12} />
        <span class="text-xs font-semibold uppercase tracking-[0.22em]">Sobrarbe · Pirineo Aragonés</span>
      </div>
      <h1
        class="font-serif font-bold text-white"
        style="font-size: clamp(2.5rem, 7vw, 5rem); line-height: 1.02; letter-spacing: -0.02em; text-shadow: 0 1px 3px rgba(0,0,0,0.5), 0 2px 16px rgba(0,0,0,0.4);"
      >
        El Sobrarbe<br />empieza aquí
      </h1>
      <p
        class="mt-6 max-w-2xl leading-relaxed"
        style="color: rgba(255,255,255,0.9); font-size: clamp(1rem, 2.2vw, 1.25rem); text-shadow: 0 1px 3px rgba(0,0,0,0.5), 0 2px 16px rgba(0,0,0,0.4);"
      >
        Castillos colgados sobre el vacío, pueblos medievales donde el tiempo parece haberse
        parado, cañones de agua turquesa y montañas que se te quedan grabadas mucho después
        de volver a casa.
      </p>
      <p
        class="mt-7 flex items-center gap-3.5 font-serif font-semibold text-white"
        style="font-size: clamp(1.3rem, 3.2vw, 2rem); line-height: 1.15; text-shadow: 0 1px 3px rgba(0,0,0,0.5), 0 2px 16px rgba(0,0,0,0.4);"
      >
        <span
          class="inline-flex items-center justify-center w-11 h-11 rounded-full flex-shrink-0"
          style="background: rgba(232,169,106,0.16); color: var(--color-ocre-suave); border: 1px solid rgba(232,169,106,0.4);"
        >
          <Icon name="clock" size={21} />
        </span>
        <span>Y todo, a <span style="color: var(--color-ocre-suave); white-space: nowrap;">menos de una hora</span> de Arcusa.</span>
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="#imprescindibles" class="btn-primary">
          Empezar a descubrir
          <Icon name="arrow-right" size={14} />
        </a>
        <a href="#mapa" class="btn-ghost">
          <Icon name="compass" size={15} />
          Ver el mapa
        </a>
      </div>
    </div>
  </section>

  <!-- Índice de navegación -->
  <div
    class="sticky top-0 z-30 hidden md:block"
    style="background: rgba(244,239,230,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(156,133,103,0.15);"
  >
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-1 overflow-x-auto" aria-label="Secciones">
      {indice.map(item => (
        <a
          href={item.href}
          class="whitespace-nowrap px-4 py-3.5 text-xs font-semibold uppercase tracking-wide transition-colors hover:text-[var(--color-ocre)]"
          style="color: var(--color-piedra-media);"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- ══════════ 2 · POR QUÉ ALOJARTE ══════════ -->
  <section class="bg-section-warm py-20 md:py-28 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-5">
          <SectionHeader
            eyebrow="El campamento base perfecto"
            title="¿Por qué alojarte en Arcusa?"
          />
          <div class="prose-arcusa">
            <p>
              El Sobrarbe no se queda corto de planes. El problema es elegir. Y para eso, lo
              mejor es dormir justo en el centro de todo.
            </p>
            <p>
              Desde Arcusa tienes la comarca entera al alcance —Aínsa, Ordesa, Guara, Alquézar—.
              Pasas el día fuera y al volver te espera un pueblo de piedra en silencio, con uno
              de los cielos más limpios del Pirineo sobre la cabeza. Aventura de día, calma de
              noche.
            </p>
          </div>
        </div>
        <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-5">
          {porQue.map((b, i) => (
            <div
              class={`reveal reveal-d${i + 1} rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1`}
              style="background: white; border: 1px solid rgba(156,133,103,0.12); box-shadow: 0 2px 8px rgba(46,42,36,0.04);"
            >
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center mb-4"
                style="background: var(--color-pergamino); color: var(--color-piedra-oscura);"
              >
                <Icon name={b.icon} size={22} />
              </div>
              <h3 class="font-serif text-lg font-semibold mb-2" style="color: var(--color-carbon);">{b.titulo}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-carbon-suave);">{b.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ 3 · IMPRESCINDIBLES ══════════ -->
  <section id="imprescindibles" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <SectionHeader
      eyebrow="Lo que no te puedes perder"
      title="Cuatro imprescindibles"
      subtitle="Si solo tuvieras un fin de semana, irías a estos cuatro sitios. Y a ninguno tardas más de una hora en llegar."
    />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {imprescindibles.map((d, i) => (
        <article
          class={`reveal reveal-d${(i % 2) + 1} card-3d rounded-3xl overflow-hidden flex flex-col`}
          style="background: white; border: 1px solid rgba(156,133,103,0.12);"
        >
          <div class="relative flex items-end overflow-hidden" style={`aspect-ratio: 16/10; background: ${d.grad};`}>
            {d.img && (
              <img src={d.img} alt={d.nombre} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover" />
            )}
            {d.img && (
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(20,24,28,0.7) 0%, transparent 55%);"></div>
            )}
            <div
              class="absolute top-4 right-4 z-10 flex items-center gap-1.5 text-xs font-semibold px-3 py-1 rounded-full"
              style="background: rgba(255,255,255,0.85); color: var(--color-carbon); backdrop-filter: blur(4px);"
            >
              <Icon name="clock" size={11} />
              {d.distancia}
            </div>
            {!d.img && (
              <div class="absolute right-5 bottom-4 opacity-25 text-white"><Icon name={d.icon} size={72} /></div>
            )}
            <div class="relative z-10 p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] mb-1" style="color: rgba(255,255,255,0.85);">{d.eyebrow}</p>
              <h3 class="font-serif text-2xl md:text-3xl font-bold text-white" style="text-shadow: 0 1px 12px rgba(0,0,0,0.25);">{d.nombre}</h3>
            </div>
          </div>
          <div class="p-6 flex-1">
