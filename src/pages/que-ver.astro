---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SectionHeader from '../components/SectionHeader.astro';
import MapaArcusa from '../components/MapaArcusa.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';

// Mapa del pueblo (se mantiene el mapa interactivo actual)
const puntos = (await getCollection('puntos')).filter(p => p.data.enMapa !== false).map(p => ({
  slug: p.id,
  nombre: p.data.nombre,
  tipo: p.data.tipo,
  x: p.data.x,
  y: p.data.y,
  resumen: p.data.resumen,
  imagenes: p.data.imagenes,
  anio: p.data.anio,
  autor: p.data.autor,
}));

// ── Navegación interna de la página ───────────────
const indice = [
  { label: 'Imprescindibles', href: '#imprescindibles' },
  { label: 'Qué visitar',     href: '#visitar' },
  { label: 'Actividades',     href: '#actividades' },
  { label: 'Experiencias',    href: '#experiencias' },
  { label: 'Gastronomía',     href: '#gastronomia' },
  { label: 'Dormir',          href: '#dormir' },
  { label: 'Itinerarios',     href: '#itinerarios' },
  { label: 'Mapa',            href: '#mapa' },
];

// ── Por qué alojarte en Arcusa ────────────────────
const porQue = [
  { icon: 'compass',   titulo: 'Todo a mano',        texto: 'Aínsa, Ordesa, Guara, Alquézar… los grandes imprescindibles del Sobrarbe quedan a un paso, sin madrugar tres horas de coche.' },
  { icon: 'tree-pine', titulo: 'Calma de verdad',    texto: 'Al volver de la aventura te espera el silencio de un pueblo de montaña, no el bullicio de un sitio masificado.' },
  { icon: 'star',      titulo: 'Cielos increíbles',  texto: 'El Sobrarbe es destino turístico Starlight. Aquí la noche todavía se ve: estrellas, Vía Láctea y silencio.' },
  { icon: 'palette',   titulo: 'Auténtico',          texto: 'Piedra, historia y un museo al aire libre en las propias calles. Te alojas dentro del patrimonio, no al lado.' },
];

// ── Imprescindibles (4 grandes) ───────────────────
const imprescindibles = [
  {
    nombre: 'Aínsa',
    eyebrow: 'Villa medieval',
    distancia: '~15 min',
    icon: 'castle',
    img: '/images/que-ver/ainsa.webp',
    grad: 'linear-gradient(135deg, #C3D7E6 0%, #7F9BBE 100%)',
    desc: 'La capital histórica del Sobrarbe. Su plaza mayor porticada, el castillo y las callejuelas de piedra forman uno de los conjuntos medievales más bonitos de Aragón. Súbete al atardecer: la luz sobre los tejados es para quedarse mudo.',
  },
  {
    nombre: 'Alquézar',
    eyebrow: 'Pueblo y cañón',
    distancia: '~45 min',
    icon: 'church',
    img: '/images/que-ver/alquezar.webp',
    grad: 'linear-gradient(135deg, #E8A96A 0%, #C4773D 100%)',
    desc: 'Un laberinto de calles colgado sobre el cañón del Vero, coronado por su colegiata. Sus pasarelas suspendidas sobre el río son uno de los paseos más espectaculares (y fotografiados) de todo el Pirineo.',
  },
  {
    nombre: 'Parque Nacional de Ordesa',
    eyebrow: 'Naturaleza mayúscula',
    distancia: '~1 h',
    icon: 'mountain',
    img: '/images/que-ver/ordesa.webp',
    grad: 'linear-gradient(135deg, #7C8A5C 0%, #3E5C3A 100%)',
    desc: 'Ordesa y Monte Perdido es uno de los grandes santuarios naturales de Europa: valles glaciares, cascadas encadenadas y paredes imposibles. Un sitio al que se va una vez y se vuelve toda la vida.',
  },
  {
    nombre: 'Sierra de Guara',
    eyebrow: 'Roca y agua',
    distancia: '~40 min',
    icon: 'waves',
    img: '/images/que-ver/guara.webp',
    grad: 'linear-gradient(135deg, #CDBBA0 0%, #6B5842 100%)',
    desc: 'El reino de los cañones. Parque Natural de la Sierra y los Cañones de Guara, capital mundial del barranquismo, con aguas turquesa, pozas y desfiladeros tallados durante milenios.',
  },
];

// ── Qué visitar (por categorías) ──────────────────
const visitar = [
  {
    titulo: 'Pueblos',
    eyebrow: 'Para perderse a pie',
    icon: 'home',
    items: [
      { n: 'Aínsa',       d: 'La joya medieval del Sobrarbe y su plaza porticada.' },
      { n: 'Alquézar',    d: 'Calles colgadas sobre el cañón del Vero.' },
      { n: 'Boltaña',     d: 'Casco antiguo y castillo a orillas del río Ara.' },
      { n: 'Abizanda',    d: 'Coronada por su torre del siglo XI sobre el embalse de Mediano.' },
      { n: 'Lecina',      d: 'Aldea de piedra junto a la milenaria Carrasca de Lecina.' },
      { n: 'Samitier',    d: 'Caserío con vistas inmensas y su ermita-castillo en la roca.' },
      { n: 'Escanilla',   d: 'Tranquilo núcleo del Sobrarbe entre campos y montaña.' },
      { n: 'Morcat',      d: 'Aldea casi despoblada, ligada al origen de Arcusa.' },
      { n: 'Muro de Roda', d: 'Conjunto fortificado medieval y mirador excepcional.' },
    ],
  },
  {
    titulo: 'Patrimonio',
    eyebrow: 'Mil años de piedra',
    icon: 'landmark',
    items: [
      { n: 'Torre de Arcusa',          d: 'La atalaya pentagonal del propio pueblo, del siglo XI.' },
      { n: 'Dolmen de Pueyoril',       d: 'Memoria prehistórica en el entorno de Arcusa.' },
      { n: 'Castillo de Samitier',     d: 'Castillo y ermita románica colgados sobre el embalse.' },
      { n: 'Castillo de Abizanda',     d: 'Torre defensiva del siglo XI con vistas de 360º.' },
      { n: 'Monasterio de San Victorián', d: 'Uno de los más antiguos de España, al pie de Peña Montañesa.' },
      { n: 'Muro de Roda',             d: 'Recinto amurallado medieval con iglesia y torreones.' },
    ],
  },
  {
    titulo: 'Naturaleza',
    eyebrow: 'Paisaje en estado puro',
    icon: 'mountain',
    items: [
      { n: 'P. N. de Ordesa y Monte Perdido', d: 'El gran parque nacional del Pirineo aragonés.' },
      { n: 'Sierra de Guara',          d: 'Parque natural y paraíso de los cañones.' },
      { n: 'Cañón del Vero',           d: 'Arte rupestre Patrimonio Mundial y pasarelas sobre el agua.' },
      { n: 'Congosto de Entremón',     d: 'Desfiladero espectacular sobre el embalse de Mediano.' },
      { n: 'Peña Montañesa',           d: 'La gran mole que vigila todo el Sobrarbe.' },
      { n: 'Miradores',                d: 'Balcones naturales con los Pirineos de fondo.' },
    ],
  },
];

// ── Actividades ───────────────────────────────────
const actividades = [
  {
    titulo: 'Senderismo',
    icon: 'footprints',
    items: [
      { n: 'GR-1, Sendero Histórico', d: 'La gran ruta que cruza el Prepirineo de punta a punta.' },
      { n: 'Ruta del Dolmen',         d: 'Un paseo corto desde Arcusa hasta la Prehistoria.' },
      { n: 'Subida a Samitier',       d: 'Castillo, ermita y un balcón sobre el embalse.' },
      { n: 'Peña Montañesa',          d: 'Ascensión exigente a uno de los miradores del Pirineo.' },
    ],
  },
  {
    titulo: 'Aventura',
    icon: 'waves',
    items: [
      { n: 'Barranquismo', d: 'Guara es la capital mundial del descenso de barrancos.' },
      { n: 'Kayak',        d: 'Aguas tranquilas en los embalses del Sobrarbe.' },
      { n: 'Rafting',      d: 'Aguas bravas en el Ara y el Cinca.' },
      { n: 'Escalada',     d: 'Paredes y escuelas para todos los niveles.' },
      { n: 'Vías ferratas', d: 'Verticalidad y adrenalina con seguridad.' },
      { n: 'BTT',          d: 'Senderos y pistas entre pueblos y montañas.' },
    ],
  },
  {
    titulo: 'Naturaleza',
    icon: 'tree-pine',
    items: [
      { n: 'Observación de aves', d: 'Uno de los mejores rincones de España para los pájaros.' },
      { n: 'Quebrantahuesos',     d: 'Avista al rey del Pirineo desde sus comederos.' },
      { n: 'Astrofotografía',     d: 'Cielos Starlight para retratar la Vía Láctea.' },
      { n: 'La berrea',           d: 'El bramido de los ciervos en pleno otoño.' },
      { n: 'Micología',           d: 'Bosques generosos en setas cuando llega el frío.' },
    ],
  },
];

// ── Experiencias ──────────────────────────────────
const experiencias = [
  { icon: 'sunrise',  texto: 'Ver amanecer desde un mirador, con el valle todavía dormido bajo la niebla.' },
  { icon: 'waves',    texto: 'Bañarte en pozas naturales de agua turquesa en pleno verano.' },
  { icon: 'castle',   texto: 'Recorrer pueblos medievales sin prisa, perdiéndote por sus callejuelas.' },
  { icon: 'palette',  texto: 'Descubrir el Museo al Aire Libre de Arcusa pintado en sus fachadas.' },
  { icon: 'star',     texto: 'Dormir bajo uno de los mejores cielos estrellados del Pirineo.' },
  { icon: 'mountain', texto: 'Fotografiar al quebrantahuesos planeando sobre los cañones.' },
  { icon: 'tree-pine', texto: 'Escuchar la berrea de los ciervos en un atardecer de otoño.' },
  { icon: 'footprints', texto: 'Cruzar las pasarelas del Vero suspendidas sobre el río.' },
];

// ── Gastronomía ───────────────────────────────────
const gastronomiaImg = '/images/que-ver/gastronomia.webp'
const productos = [
  { n: 'Ternasco de Aragón', icon: 'utensils' },
  { n: 'Chiretas',           icon: 'utensils' },
  { n: 'Longaniza',          icon: 'utensils' },
  { n: 'Quesos del Pirineo', icon: 'utensils' },
  { n: 'Miel de montaña',    icon: 'sparkles' },
  { n: 'Aceite',             icon: 'sparkles' },
  { n: 'Vinos D.O. Somontano', icon: 'star' },
];

// ── Dormir ────────────────────────────────────────
const alojamiento = [
  { icon: 'home',     titulo: 'Casas rurales',  texto: 'La forma más auténtica de dormir en el Sobrarbe. En la propia Arcusa encontrarás alojamiento de piedra con encanto.' },
  { icon: 'building', titulo: 'Hoteles',        texto: 'En Aínsa, Boltaña y alrededores, desde acogedores hoteles con encanto a opciones para toda la familia.' },
  { icon: 'tree-pine', titulo: 'Campings',      texto: 'Para quien prefiere despertar entre pinos, junto al río o bajo las estrellas.' },
  { icon: 'bed',      titulo: 'Apartamentos',   texto: 'Independencia y comodidad para estancias largas o viajes en familia.' },
];

// ── Itinerarios ───────────────────────────────────
const itinerarios = [
  { tiempo: 'Medio día',   icon: 'clock',    titulo: 'Aínsa al atardecer',     plan: 'Pasea por el casco medieval de Aínsa, sube al castillo y quédate a ver caer el sol sobre los Pirineos. Vuelve a cenar a la calma de Arcusa.' },
  { tiempo: 'Un día',      icon: 'sunrise',  titulo: 'Alquézar y el Vero',     plan: 'Madruga hacia Alquézar, recorre sus pasarelas sobre el cañón del Vero y come en el pueblo. Por la tarde, baño en una poza si aprieta el calor.' },
  { tiempo: 'Fin de semana', icon: 'calendar', titulo: 'Ordesa + Sobrarbe',   plan: 'Un día entero en Ordesa para la gran naturaleza y otro repartido entre Aínsa, los pueblos cercanos y el patrimonio de Arcusa.' },
  { tiempo: '3 días',      icon: 'star',     titulo: 'La inmersión total',     plan: 'Suma a lo anterior una jornada de aventura en Guara —barranco o ferrata— y tiempo para los rincones menos turísticos del Sobrarbe.' },
];

// ── Según la época ────────────────────────────────
const estaciones = [
  { estacion: 'Primavera', icon: 'tree-pine', texto: 'El deshielo dispara las cascadas y los barrancos. Verde por todas partes y pueblos sin agobios.' },
  { estacion: 'Verano',    icon: 'waves',     texto: 'Temporada de pozas, barranquismo y noches templadas para mirar las estrellas.' },
  { estacion: 'Otoño',     icon: 'star',      texto: 'El bosque se vuelve de oro, llega la berrea y salen las setas. Quizá la mejor época.' },
  { estacion: 'Invierno',  icon: 'sparkles',  texto: 'Silencio, nieve en las cumbres y un Sobrarbe tranquilo para desconectar de verdad.' },
];

// ── Familia ───────────────────────────────────────
const familia = [
  'Las pasarelas del Vero, una aventura segura que encanta a los niños.',
  'Baños en pozas y orillas tranquilas durante el verano.',
  'El museo al aire libre de Arcusa, un juego para buscar murales por las calles.',
  'Observación de fauna y aves: quebrantahuesos, buitres y ciervos.',
  'Pueblos medievales para explorar como pequeños castillos de verdad.',
];

// ── Rincones poco conocidos ───────────────────────
const rincones = [
  { n: 'Muro de Roda',          d: 'Un recinto fortificado medieval casi secreto, con vistas que pagan la subida.' },
  { n: 'La Carrasca de Lecina', d: 'Una encina milenaria y monumental junto a una aldea de piedra.' },
  { n: 'Congosto de Entremón',  d: 'Un desfiladero impresionante que muy pocos visitantes conocen.' },
  { n: 'Samitier',              d: 'Castillo y ermita colgados en la roca, lejos de las multitudes.' },
  { n: 'Aldeas despobladas',    d: 'Morcat y otros núcleos donde el tiempo parece haberse parado.' },
];
---

<Layout
  title="Descubre el Sobrarbe desde Arcusa – Qué ver y hacer"
  description="Arcusa es el mejor punto de partida para descubrir el Sobrarbe: Aínsa, Alquézar, Ordesa, la Sierra de Guara, pueblos medievales, cañones, rutas y experiencias en el Pirineo aragonés."
>
  <Navigation />

  <!-- ══════════ 1 · HERO ══════════ -->
  <section
    class="relative flex items-end overflow-hidden"
    style="height: 88svh; min-height: 600px;"
    aria-label="Descubre el Sobrarbe desde Arcusa"
  >
    <img
      src="/images/hero/Header4.webp"
      alt="Paisaje de montañas del Sobrarbe, en el Pirineo aragonés"
      class="absolute inset-0 w-full h-full object-cover"
      style="object-position: center 30%;"
      fetchpriority="high"
    />
    <!-- Velo para legibilidad -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(to top, rgba(20,24,28,0.78) 0%, rgba(20,24,28,0.32) 45%, rgba(20,24,28,0.18) 100%);"
    ></div>
    <!-- Transición al cuerpo -->
    <div
      class="absolute inset-x-0 bottom-0 h-32 pointer-events-none"
      style="background: linear-gradient(to bottom, transparent, var(--color-pergamino));"
    ></div>

    <div class="relative z-10 w-full max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pb-24 md:pb-28">
      <div
        class="inline-flex items-center gap-2 mb-6 px-4 py-1.5 rounded-full"
        style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,0.18); color: rgba(255,255,255,0.85);"
      >
        <Icon name="map-pin" size={12} />
        <span class="text-xs font-semibold uppercase tracking-[0.22em]">Sobrarbe · Pirineo Aragonés</span>
      </div>
      <h1
        class="font-serif font-bold text-white"
        style="font-size: clamp(2.5rem, 7vw, 5rem); line-height: 1.02; letter-spacing: -0.02em; text-shadow: 0 2px 28px rgba(0,0,0,0.3);"
      >
        Descubre el Sobrarbe<br />desde Arcusa
      </h1>
      <p
        class="mt-6 max-w-2xl leading-relaxed"
        style="color: rgba(255,255,255,0.9); font-size: clamp(1rem, 2.2vw, 1.25rem); text-shadow: 0 1px 12px rgba(0,0,0,0.3);"
      >
        Arcusa es un excelente punto de partida para descubrir algunos de los paisajes más
        espectaculares del Pirineo aragonés. En menos de una hora puedes recorrer pueblos
        medievales, cañones, ríos de aguas cristalinas, miradores, castillos y uno de los
        parques nacionales más importantes de España.
      </p>
      <div class="mt-9 flex flex-wrap gap-3">
        <a href="#imprescindibles" class="btn-primary">
          Empezar a descubrir
          <Icon name="arrow-right" size={14} />
        </a>
        <a href="#mapa" class="btn-ghost">
          <Icon name="compass" size={15} />
          Ver el mapa
        </a>
      </div>
    </div>
  </section>

  <!-- Índice de navegación -->
  <div
    class="sticky top-0 z-30 hidden md:block"
    style="background: rgba(244,239,230,0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(156,133,103,0.15);"
  >
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-1 overflow-x-auto" aria-label="Secciones">
      {indice.map(item => (
        <a
          href={item.href}
          class="whitespace-nowrap px-4 py-3.5 text-xs font-semibold uppercase tracking-wide transition-colors hover:text-[var(--color-ocre)]"
          style="color: var(--color-piedra-media);"
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>

  <!-- ══════════ 2 · POR QUÉ ALOJARTE ══════════ -->
  <section class="bg-section-warm py-20 md:py-28 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
        <div class="lg:col-span-5">
          <SectionHeader
            eyebrow="El campamento base perfecto"
            title="¿Por qué alojarte en Arcusa?"
          />
          <div class="prose-arcusa">
            <p>
              Lo difícil del Sobrarbe no es encontrar qué hacer: es elegir. Y para eso, lo
              mejor es dormir en el centro de todo.
            </p>
            <p>
              Desde Arcusa visitas la comarca entera —Aínsa, Ordesa, Guara, Alquézar— y al
              final del día vuelves a un pueblo de piedra tranquilo, lejos del turismo masivo,
              con uno de los cielos más limpios del Pirineo sobre tu cabeza. Aventura por el
              día, calma por la noche.
            </p>
          </div>
        </div>
        <div class="lg:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-5">
          {porQue.map((b, i) => (
            <div
              class={`reveal reveal-d${i + 1} rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1`}
              style="background: white; border: 1px solid rgba(156,133,103,0.12); box-shadow: 0 2px 8px rgba(46,42,36,0.04);"
            >
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center mb-4"
                style="background: var(--color-pergamino); color: var(--color-piedra-oscura);"
              >
                <Icon name={b.icon} size={22} />
              </div>
              <h3 class="font-serif text-lg font-semibold mb-2" style="color: var(--color-carbon);">{b.titulo}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--color-carbon-suave);">{b.texto}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ 3 · IMPRESCINDIBLES ══════════ -->
  <section id="imprescindibles" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <SectionHeader
      eyebrow="Lo que no te puedes perder"
      title="Cuatro imprescindibles"
      subtitle="Si solo te diera tiempo a ver cuatro cosas cerca de Arcusa, serían estas. Y las cuatro están a menos de una hora."
    />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {imprescindibles.map((d, i) => (
        <article
          class={`reveal reveal-d${(i % 2) + 1} card-3d rounded-3xl overflow-hidden flex flex-col`}
          style="background: white; border: 1px solid rgba(156,133,103,0.12);"
        >
          <div class="relative flex items-end overflow-hidden" style={`aspect-ratio: 16/10; background: ${d.grad};`}>
            {d.img && (
              <img src={d.img} alt={d.nombre} loading="lazy" decoding="async" class="absolute inset-0 w-full h-full object-cover" />
            )}
            {d.img && (
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(20,24,28,0.7) 0%, transparent 55%);"></div>
            )}
            <div
              class="absolute top-4 right-4 z-10 flex items-center gap-1.5 text-xs font-semibold px-3 py-1 rounded-full"
              style="background: rgba(255,255,255,0.85); color: var(--color-carbon); backdrop-filter: blur(4px);"
            >
              <Icon name="clock" size={11} />
              {d.distancia}
            </div>
            {!d.img && (
              <div class="absolute right-5 bottom-4 opacity-25 text-white"><Icon name={d.icon} size={72} /></div>
            )}
            <div class="relative z-10 p-6">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] mb-1" style="color: rgba(255,255,255,0.85);">{d.eyebrow}</p>
              <h3 class="font-serif text-2xl md:text-3xl font-bold text-white" style="text-shadow: 0 1px 12px rgba(0,0,0,0.25);">{d.nombre}</h3>
            </div>
          </div>
          <div class="p-6 flex-1">
            <p class="leading-relaxed" style="color: var(--color-carbon-suave);">{d.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ══════════ 4 · QUÉ VISITAR ══════════ -->
  <section id="visitar" style="background: white;" class="py-20 md:py-28 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        eyebrow="Para todos los planes"
        title="Qué visitar"
        subtitle="Pueblos con siglos de historia, patrimonio de piedra y naturaleza de la grande. Elige por lo que te apetezca hoy."
      />
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {visitar.map((cat, ci) => (
          <div class={`reveal reveal-d${ci + 1}`}>
            <div class="flex items-center gap-3 mb-5">
              <div
                class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
                style="background: var(--color-pergamino); color: var(--color-piedra-oscura);"
              >
                <Icon name={cat.icon} size={20} />
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em]" style="color: var(--color-ocre);">{cat.eyebrow}</p>
                <h3 class="font-serif text-xl font-semibold" style="color: var(--color-carbon);">{cat.titulo}</h3>
              </div>
            </div>
            <ul class="flex flex-col">
              {cat.items.map(item => (
                <li class="py-3 flex gap-3" style="border-top: 1px solid rgba(156,133,103,0.12);">
                  <Icon name="chevron-right" size={14} class="flex-shrink-0 mt-1" style="color: var(--color-piedra-clara);" />
                  <div>
                    <p class="font-semibold text-sm" style="color: var(--color-carbon);">{item.n}</p>
                    <p class="text-sm leading-snug mt-0.5" style="color: var(--color-carbon-suave);">{item.d}</p>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ 5 · ACTIVIDADES ══════════ -->
  <section id="actividades" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <SectionHeader
      eyebrow="Para los que no paran quietos"
      title="Actividades"
      subtitle="El Sobrarbe es uno de los grandes patios de juego al aire libre de Europa. Aquí va de qué te puedes llenar los días."
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {actividades.map((cat, ci) => (
        <div
          class={`reveal reveal-d${ci + 1} rounded-2xl p-6 md:p-7`}
          style="background: white; border: 1px solid rgba(156,133,103,0.12); box-shadow: 0 2px 8px rgba(46,42,36,0.04);"
        >
          <div class="flex items-center gap-3 mb-5">
            <div
              class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0"
              style="background: var(--color-cielo-palido); color: var(--color-azul-pirineo);"
            >
              <Icon name={cat.icon} size={20} />
            </div>
            <h3 class="font-serif text-xl font-semibold" style="color: var(--color-carbon);">{cat.titulo}</h3>
          </div>
          <ul class="flex flex-col gap-3.5">
            {cat.items.map(item => (
              <li class="flex gap-2.5">
                <Icon name="check" size={15} class="flex-shrink-0 mt-0.5" style="color: var(--color-verde-medio);" />
                <div>
                  <span class="font-semibold text-sm" style="color: var(--color-carbon);">{item.n}.</span>
                  <span class="text-sm" style="color: var(--color-carbon-suave);"> {item.d}</span>
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ══════════ 6 · EXPERIENCIAS ══════════ -->
  <section id="experiencias" class="bg-section-dark py-20 md:py-28 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <SectionHeader
        eyebrow="No coleccionas sitios, coleccionas momentos"
        title="Experiencias para recordar"
        subtitle="Olvídate por un momento de la lista de lugares. Estas son las cosas que de verdad te vas a llevar a casa."
        dark
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-2">
        {experiencias.map((e, i) => (
          <div
            class={`reveal reveal-d${(i % 4) + 1} flex items-center gap-4 py-4`}
            style="border-bottom: 1px solid rgba(255,255,255,0.1);"
          >
            <div
              class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0"
              style="background: rgba(255,255,255,0.08); color: var(--color-ocre-suave);"
            >
              <Icon name={e.icon} size={19} />
            </div>
            <p class="leading-relaxed" style="color: rgba(255,255,255,0.82);">{e.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ 7 · GASTRONOMÍA ══════════ -->
  <section id="gastronomia" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <SectionHeader
          eyebrow="Sabor de montaña"
          title="Comer en el Sobrarbe"
        />
        <div class="prose-arcusa">
          <p>
            Aquí se come de verdad. Cocina de montaña, contundente y honesta, hecha con lo que
            da la tierra y pensada para reponer fuerzas después de un día de aventura.
          </p>
          <p>
            En Arcusa y los pueblos de alrededor encontrarás bares y restaurantes donde probar
            los guisos de siempre. Y si te llevas algo a casa, que sea de aquí.
          </p>
        </div>
        <p class="mt-8 text-xs font-semibold uppercase tracking-[0.18em] mb-4" style="color: var(--color-ocre);">
          Productos típicos
        </p>
        <div class="flex flex-wrap gap-2.5">
          {productos.map(p => (
            <span
              class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium"
              style="background: white; border: 1px solid rgba(156,133,103,0.2); color: var(--color-carbon-suave);"
            >
              <Icon name={p.icon} size={13} style="color: var(--color-piedra-media);" />
              {p.n}
            </span>
          ))}
        </div>
      </div>
      <div
        class="rounded-3xl overflow-hidden flex items-center justify-center"
        style="aspect-ratio: 4/3; background: linear-gradient(135deg, var(--color-pergamino) 0%, var(--color-piedra-clara) 100%);"
      >
        {gastronomiaImg ? (
          <img src={gastronomiaImg} alt="Gastronomía del Sobrarbe" loading="lazy" decoding="async" class="w-full h-full object-cover" />
        ) : (
          <div class="text-center" style="color: var(--color-piedra-media);">
            <Icon name="utensils" size={48} class="mx-auto mb-3 opacity-40" />
            <p class="text-sm">Fotografía próximamente</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ══════════ 8 · DORMIR ══════════ -->
  <section id="dormir" class="bg-section-white-warm py-20 md:py-28 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        eyebrow="Tu base en el Sobrarbe"
        title="Dónde dormir"
        subtitle="Desde casas rurales de piedra hasta campings junto al río. Sea cual sea tu plan, hay un sitio para descansar."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {alojamiento.map((a, i) => (
          <div
            class={`reveal reveal-d${i + 1} rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1`}
            style="background: white; border: 1px solid rgba(156,133,103,0.12); box-shadow: 0 2px 8px rgba(46,42,36,0.04);"
          >
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center mb-4"
              style="background: var(--color-pergamino); color: var(--color-piedra-oscura);"
            >
              <Icon name={a.icon} size={22} />
            </div>
            <h3 class="font-serif text-lg font-semibold mb-2" style="color: var(--color-carbon);">{a.titulo}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-carbon-suave);">{a.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ 9 · ITINERARIOS ══════════ -->
  <section id="itinerarios" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <SectionHeader
      eyebrow="¿Cuánto tiempo tienes?"
      title="Itinerarios a tu medida"
      subtitle="Da igual que vengas a pasar la tarde o una semana entera: aquí tienes por dónde empezar."
    />
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {itinerarios.map((it, i) => (
        <article
          class={`reveal reveal-d${(i % 2) + 1} rounded-2xl p-7 flex gap-5`}
          style="background: white; border: 1px solid rgba(156,133,103,0.12); box-shadow: 0 2px 8px rgba(46,42,36,0.04);"
        >
          <div
            class="w-14 h-14 rounded-2xl flex items-center justify-center flex-shrink-0"
            style="background: var(--color-cielo-palido); color: var(--color-azul-pirineo);"
          >
            <Icon name={it.icon} size={24} />
          </div>
          <div>
            <span
              class="inline-block text-xs font-bold uppercase tracking-wide mb-2 px-2.5 py-0.5 rounded-full"
              style="background: var(--color-pergamino); color: var(--color-ocre);"
            >
              {it.tiempo}
            </span>
            <h3 class="font-serif text-xl font-semibold mb-2" style="color: var(--color-carbon);">{it.titulo}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-carbon-suave);">{it.plan}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ══════════ 10 · SEGÚN LA ÉPOCA ══════════ -->
  <section style="background: white;" class="py-20 md:py-28 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        eyebrow="El Sobrarbe cambia con el calendario"
        title="Según la época del año"
        subtitle="No hay una mala estación para venir. Solo planes distintos."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {estaciones.map((e, i) => (
          <div
            class={`reveal reveal-d${i + 1} rounded-2xl p-6 h-full`}
            style="background: var(--color-pergamino); border: 1px solid rgba(156,133,103,0.12);"
          >
            <div
              class="w-12 h-12 rounded-xl flex items-center justify-center mb-4"
              style="background: white; color: var(--color-verde-medio);"
            >
              <Icon name={e.icon} size={22} />
            </div>
            <h3 class="font-serif text-lg font-semibold mb-2" style="color: var(--color-carbon);">{e.estacion}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-carbon-suave);">{e.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ 11 · FAMILIA · 12 · RINCONES ══════════ -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Familia -->
      <div class="reveal">
        <SectionHeader eyebrow="Para los más pequeños" title="Viaje en familia" />
        <ul class="flex flex-col gap-4">
          {familia.map(f => (
            <li class="flex gap-3.5 items-start">
              <div
                class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0"
                style="background: var(--color-cielo-palido); color: var(--color-azul-pirineo);"
              >
                <Icon name="check" size={15} />
              </div>
              <p class="leading-relaxed pt-1" style="color: var(--color-carbon-suave);">{f}</p>
            </li>
          ))}
        </ul>
      </div>
      <!-- Rincones -->
      <div class="reveal reveal-d1">
        <SectionHeader eyebrow="Lejos del mapa turístico" title="Rincones poco conocidos" />
        <ul class="flex flex-col">
          {rincones.map(r => (
            <li class="py-4 flex gap-3" style="border-top: 1px solid rgba(156,133,103,0.12);">
              <Icon name="compass" size={16} class="flex-shrink-0 mt-1" style="color: var(--color-ocre);" />
              <div>
                <p class="font-semibold" style="color: var(--color-carbon);">{r.n}</p>
                <p class="text-sm leading-snug mt-0.5" style="color: var(--color-carbon-suave);">{r.d}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ══════════ Enlace a Arcusa de noche ══════════ -->
  <section class="bg-section-dark py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-6 md:gap-10 text-center md:text-left">
      <div class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0" style="background: rgba(159,192,224,0.14); color:#9FC0E0;">
        <Icon name="moon" size={30} />
      </div>
      <div class="flex-1">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] mb-2" style="color: rgba(232,169,106,0.9);">Cuando se apaga el día</p>
        <h2 class="font-serif text-2xl sm:text-3xl font-semibold text-white mb-2">También puedes descubrir Arcusa de noche</h2>
        <p class="leading-relaxed" style="color: rgba(255,255,255,0.72);">Cielos limpios, silencio y estrellas sobre el Sobrarbe, primer Destino Starlight de Huesca.</p>
      </div>
      <a href="/arcusa-de-noche" class="btn-ghost flex-shrink-0">
        <Icon name="moon" size={15} />
        Arcusa de noche
      </a>
    </div>
  </section>

  <!-- ══════════ 13 · MAPA ══════════ -->
  <section id="mapa" class="bg-section-warm py-20 md:py-24 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <SectionHeader
        eyebrow="Sobre el terreno"
        title="Explora Arcusa en el mapa"
        subtitle="Antes de salir a recorrer la comarca, descubre el propio pueblo: casas con historia, los cuadros del museo al aire libre y sus servicios."
        centered
      />
      <MapaArcusa puntos={puntos} />
    </div>
  </section>

  <!-- ══════════ 14 · CTA FINAL ══════════ -->
  <section class="bg-section-blue py-24 px-4">
    <div class="max-w-2xl mx-auto text-center text-white">
      <p class="text-xs font-semibold uppercase tracking-[0.25em] mb-5" style="color: rgba(255,255,255,0.6);">
        Tu próxima escapada empieza aquí
      </p>
      <h2 class="font-serif font-bold leading-tight mb-5" style="font-size: clamp(1.9rem, 4.5vw, 3rem);">
        No sabías que había tanto por ver cerca de Arcusa
      </h2>
      <p class="text-lg leading-relaxed mb-9" style="color: rgba(255,255,255,0.82);">
        Pueblos medievales, cañones, parques naturales y cielos estrellados, todo desde un
        pueblo de piedra del Sobrarbe. Ven, quédate y descúbrelo a tu ritmo.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a
          href="/explora"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold transition-all hover:scale-105"
          style="background: white; color: var(--color-azul-pirineo);"
        >
          <Icon name="compass" size={15} />
          Explorar el pueblo
        </a>
        <a
          href="/historia"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold transition-all hover:scale-105"
          style="border: 1.5px solid rgba(255,255,255,0.4); color: white;"
        >
          <Icon name="scroll" size={15} />
          Conoce su historia
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
